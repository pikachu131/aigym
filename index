                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                gap: 30px;
                transform: translateX(100%);
                transition: transform 0.4s ease;
            }

            .mobile-menu.active { transform: translateX(0); }

            .mobile-menu a {
                color: var(--text);
